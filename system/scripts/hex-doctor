#!/bin/bash
# hex-doctor — Unified health check entry point for all hex modules
#
# Runs installation checks (via doctor.sh) + all 6 module checks:
#   Memory → hex-events → BOI → startup → landings → workspace
#
# Usage:
#   hex-doctor              # Check all modules, report results
#   hex-doctor --fix        # Auto-fix issues where possible
#   hex-doctor --smoke      # Also run smoke tests (slower, proves end-to-end)
#   hex-doctor --quiet      # Only show errors and warnings
#
# Exit codes:
#   0 = all pass
#   1 = errors found
#   2 = warnings only (no errors)

set -uo pipefail

# ─── Resolve HEX_DIR ────────────────────────────────────────────────────────
if [ -z "${HEX_DIR:-}" ]; then
  SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  candidate="$SCRIPT_DIR"
  while [ "$candidate" != "/" ]; do
    if [ -f "$candidate/CLAUDE.md" ]; then
      HEX_DIR="$candidate"
      break
    fi
    candidate="$(dirname "$candidate")"
  done
  HEX_DIR="${HEX_DIR:-${HEX_DIR:-$HOME/hex}}"
fi

CLAUDE_DIR="$HEX_DIR/.hex"
SCRIPTS_DIR="$HEX_DIR/.hex/scripts"
HEX_CHECKS_DIR="$HEX_DIR/.hex/scripts/doctor-checks"

# ─── Flags ────────────────────────────────────────────────────────────────────
FIX=false
SMOKE=false
QUIET=false

for arg in "$@"; do
  case "$arg" in
    --fix)   FIX=true ;;
    --smoke) SMOKE=true ;;
    --quiet) QUIET=true ;;
    --help|-h)
      echo "Usage: hex-doctor [--fix] [--smoke] [--quiet]"
      echo ""
      echo "  --fix    Auto-fix safe issues (restarts daemons, chmod, rebuilds indexes)"
      echo "  --smoke  Run smoke tests proving end-to-end functionality (slower)"
      echo "  --quiet  Only show errors and warnings (suppress PASS lines)"
      exit 0
      ;;
    *) echo "Unknown option: $arg" >&2; exit 1 ;;
  esac
done

# ─── Colors ───────────────────────────────────────────────────────────────────
GREEN='\033[32m'
YELLOW='\033[33m'
RED='\033[31m'
BOLD='\033[1m'
DIM='\033[2m'
RESET='\033[0m'

# ─── State ────────────────────────────────────────────────────────────────────
PASS_COUNT=0
WARN_COUNT=0
ERROR_COUNT=0
FIXED_COUNT=0
HAS_ERRORS=false
HAS_WARNINGS=false

CHECKS_FILE=$(mktemp /tmp/hex-doctor-checks.XXXXXX)
DOCTOR_TMP=$(mktemp -t hex-doctor-XXXXXX)
trap 'rm -f "$CHECKS_FILE" "$DOCTOR_TMP"' EXIT

# ─── Output helpers ───────────────────────────────────────────────────────────
_pass() {
  PASS_COUNT=$((PASS_COUNT + 1))
  if ! $QUIET; then
    echo -e "  [${GREEN}PASS${RESET}] $1"
  fi
}

_warn() {
  WARN_COUNT=$((WARN_COUNT + 1))
  HAS_WARNINGS=true
  echo -e "  [${YELLOW}WARN${RESET}] $1"
}

_error() {
  ERROR_COUNT=$((ERROR_COUNT + 1))
  HAS_ERRORS=true
  echo -e "  [${RED}ERROR${RESET}] $1"
}

_fixed() {
  FIXED_COUNT=$((FIXED_COUNT + 1))
  echo -e "  [${GREEN}FIXED${RESET}] $1"
}

_info() {
  if ! $QUIET; then
    echo -e "  ${DIM}→${RESET} $1"
  fi
}

_rec() {
  printf '%s\t%s\t%s\t%s\n' "$1" "$2" "$3" "$4" >> "$CHECKS_FILE"
}

# ─── Header ───────────────────────────────────────────────────────────────────
echo ""
echo -e "${BOLD}Hex Doctor — Full System Health Check${RESET}"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo -e "${DIM}HEX_DIR=$HEX_DIR${RESET}"
if $FIX;   then echo -e "${DIM}Mode: --fix enabled (auto-remediation on)${RESET}"; fi
if $SMOKE; then echo -e "${DIM}Mode: --smoke enabled (end-to-end tests on)${RESET}"; fi

# ─── Part 1: Installation checks (doctor.sh) ─────────────────────────────────
DOCTOR_SH="$SCRIPTS_DIR/doctor.sh"
INSTALL_ERRORS=0
INSTALL_WARNINGS=0
INSTALL_PASS=0
INSTALL_FIXED=0

if [ -f "$DOCTOR_SH" ]; then
  echo ""
  echo -e "${BOLD}Installation Checks${RESET}"
  echo "  ─────────────────────────────────────────"

  # Stream doctor.sh output live to the terminal AND tee to a temp file so we
  # can parse the summary line afterward. Capturing into a variable buffered the
  # entire run — caused the appearance of hangs during integration checks.
  # tail -n +5 strips doctor.sh's own header (4 lines) so it doesn't duplicate
  # the bold "Installation Checks" header we just printed.
  if $FIX && $QUIET; then
    bash "$DOCTOR_SH" --fix --quiet 2>&1 | tee "$DOCTOR_TMP" | tail -n +5
  elif $FIX; then
    bash "$DOCTOR_SH" --fix 2>&1 | tee "$DOCTOR_TMP" | tail -n +5
  elif $QUIET; then
    bash "$DOCTOR_SH" --quiet 2>&1 | tee "$DOCTOR_TMP" | tail -n +5
  else
    bash "$DOCTOR_SH" 2>&1 | tee "$DOCTOR_TMP" | tail -n +5
  fi
  # PIPESTATUS[0]=doctor.sh, [1]=tee, [2]=tail. Without -e we keep going on
  # failure, so capture all three and surface explicitly. tee failing (disk full,
  # permission, ENOSPC) while doctor.sh exits 0 was a silent-failure path.
  doctor_sh_exit="${PIPESTATUS[0]}"
  doctor_tee_exit="${PIPESTATUS[1]:-0}"
  doctor_tail_exit="${PIPESTATUS[2]:-0}"
  doctor_output="$(cat "$DOCTOR_TMP")"

  # Parse summary from doctor.sh output: "  Summary: N passed, N warnings, N errors, N fixed"
  summary_line=$(echo "$doctor_output" | grep "Summary:" | tail -1) || summary_line=""
  if [ -n "$summary_line" ]; then
    INSTALL_PASS=$(echo "$summary_line"   | grep -oE '[0-9]+ passed'   | grep -oE '[0-9]+' || echo 0)
    INSTALL_WARNINGS=$(echo "$summary_line" | grep -oE '[0-9]+ warnings' | grep -oE '[0-9]+' || echo 0)
    INSTALL_ERRORS=$(echo "$summary_line"   | grep -oE '[0-9]+ errors'   | grep -oE '[0-9]+' || echo 0)
    INSTALL_FIXED=$(echo "$summary_line"    | grep -oE '[0-9]+ fixed'    | grep -oE '[0-9]+' || echo 0)
    # Merge into global counts
    PASS_COUNT=$((PASS_COUNT + ${INSTALL_PASS:-0}))
    WARN_COUNT=$((WARN_COUNT + ${INSTALL_WARNINGS:-0}))
    ERROR_COUNT=$((ERROR_COUNT + ${INSTALL_ERRORS:-0}))
    FIXED_COUNT=$((FIXED_COUNT + ${INSTALL_FIXED:-0}))
    [ "${INSTALL_ERRORS:-0}" -gt 0 ] && HAS_ERRORS=true
    [ "${INSTALL_WARNINGS:-0}" -gt 0 ] && HAS_WARNINGS=true
  elif [ "${doctor_sh_exit:-1}" -ne 0 ]; then
    _error "Installation checks crashed (doctor.sh exit $doctor_sh_exit) — no Summary line"
    HAS_ERRORS=true
  elif [ "${doctor_tee_exit:-0}" -ne 0 ] || [ "${doctor_tail_exit:-0}" -ne 0 ]; then
    _error "Installation checks output pipeline failed (tee=$doctor_tee_exit tail=$doctor_tail_exit) — Summary may be incomplete"
    HAS_ERRORS=true
  else
    _error "Installation checks produced no Summary line — counts unverified"
    HAS_ERRORS=true
  fi
else
  _warn "Installation checks skipped: doctor.sh not found at $DOCTOR_SH"
fi

# ─── Part 2: Module checks ────────────────────────────────────────────────────
MODULE_COUNT=0
CHAIN_STOPPED=false

if [ ! -d "$HEX_CHECKS_DIR" ]; then
  echo ""
  _warn "Module checks dir not found: $HEX_CHECKS_DIR"
else

  # ── Memory (critical) ────────────────────────────────────────────────────────
  if [ -f "$HEX_CHECKS_DIR/memory.sh" ]; then
    MODULE_COUNT=$((MODULE_COUNT + 1))
    echo ""
    echo -e "${BOLD}Memory Module${RESET}"
    echo "  ─────────────────────────────────────────"
    _ERRORS_BEFORE=$ERROR_COUNT
    source "$HEX_CHECKS_DIR/memory.sh"
    run_memory_checks
    if [ "$ERROR_COUNT" -gt "$_ERRORS_BEFORE" ]; then
      CHAIN_STOPPED=true
    fi
  fi

  # ── hex-events ───────────────────────────────────────────────────────────────
  if [ -f "$HEX_CHECKS_DIR/hex-events.sh" ] && ! $CHAIN_STOPPED; then
    MODULE_COUNT=$((MODULE_COUNT + 1))
    echo ""
    echo -e "${BOLD}hex-events Module${RESET}"
    echo "  ─────────────────────────────────────────"
    source "$HEX_CHECKS_DIR/hex-events.sh"
    run_hex_events_checks
  elif [ -f "$HEX_CHECKS_DIR/hex-events.sh" ] && $CHAIN_STOPPED; then
    MODULE_COUNT=$((MODULE_COUNT + 1))
    echo ""
    echo -e "  ${DIM}[SKIP] hex-events — blocked by memory errors${RESET}"
  fi

  # ── BOI ──────────────────────────────────────────────────────────────────────
  if [ -f "$HEX_CHECKS_DIR/boi.sh" ] && ! $CHAIN_STOPPED; then
    MODULE_COUNT=$((MODULE_COUNT + 1))
    echo ""
    echo -e "${BOLD}BOI Module${RESET}"
    echo "  ─────────────────────────────────────────"
    source "$HEX_CHECKS_DIR/boi.sh"
    run_boi_checks
  elif [ -f "$HEX_CHECKS_DIR/boi.sh" ] && $CHAIN_STOPPED; then
    MODULE_COUNT=$((MODULE_COUNT + 1))
    echo ""
    echo -e "  ${DIM}[SKIP] BOI — blocked by memory errors${RESET}"
  fi

  # ── Startup ──────────────────────────────────────────────────────────────────
  if [ -f "$HEX_CHECKS_DIR/startup.sh" ] && ! $CHAIN_STOPPED; then
    MODULE_COUNT=$((MODULE_COUNT + 1))
    echo ""
    echo -e "${BOLD}Startup Module${RESET}"
    echo "  ─────────────────────────────────────────"
    source "$HEX_CHECKS_DIR/startup.sh"
    run_startup_checks
  elif [ -f "$HEX_CHECKS_DIR/startup.sh" ] && $CHAIN_STOPPED; then
    MODULE_COUNT=$((MODULE_COUNT + 1))
    echo ""
    echo -e "  ${DIM}[SKIP] Startup — blocked by memory errors${RESET}"
  fi

  # ── Landings + Workspace (always run even if chain stopped) ──────────────────
  if [ -f "$HEX_CHECKS_DIR/landings-workspace.sh" ]; then
    source "$HEX_CHECKS_DIR/landings-workspace.sh"

    MODULE_COUNT=$((MODULE_COUNT + 1))
    echo ""
    echo -e "${BOLD}Landings Module${RESET}"
    echo "  ─────────────────────────────────────────"
    check_61
    check_62

    MODULE_COUNT=$((MODULE_COUNT + 1))
    echo ""
    echo -e "${BOLD}Workspace Module${RESET}"
    echo "  ─────────────────────────────────────────"
    check_63
    check_64
    check_65
  fi

fi

# ─── Alert Pipeline check ─────────────────────────────────────────────────────
ALERT_PIPELINE_CHECK="$SCRIPTS_DIR/health/check-alert-pipeline.sh"
if [ -f "$ALERT_PIPELINE_CHECK" ]; then
  MODULE_COUNT=$((MODULE_COUNT + 1))
  echo ""
  echo -e "${BOLD}Alert Pipeline${RESET}"
  echo "  ─────────────────────────────────────────"
  alert_out=""
  alert_exit=0
  alert_out="$(bash "$ALERT_PIPELINE_CHECK" 2>&1)" || alert_exit=$?
  if [ "$alert_exit" -eq 0 ]; then
    _pass "$alert_out"
  else
    _error "$alert_out"
  fi
fi

# ─── Reflection Liveness check ───────────────────────────────────────────────
REFLECTION_LIVENESS_CHECK="$SCRIPTS_DIR/health/check-reflection-liveness.sh"
if [ -f "$REFLECTION_LIVENESS_CHECK" ]; then
  MODULE_COUNT=$((MODULE_COUNT + 1))
  echo ""
  echo -e "${BOLD}Reflection Liveness${RESET}"
  echo "  ─────────────────────────────────────────"
  rl_out=""
  rl_exit=0
  rl_out="$(bash "$REFLECTION_LIVENESS_CHECK" 2>&1)" || rl_exit=$?
  if [ "$rl_exit" -eq 0 ]; then
    _pass "$rl_out"
  else
    _error "$rl_out"
  fi
fi

# ─── BOI DB Canonical check ───────────────────────────────────────────────────
BOI_DB_CHECK="$SCRIPTS_DIR/health/check-boi-db-canonical.sh"
if [ -f "$BOI_DB_CHECK" ]; then
  MODULE_COUNT=$((MODULE_COUNT + 1))
  echo ""
  echo -e "${BOLD}BOI DB Canonical${RESET}"
  echo "  ─────────────────────────────────────────"
  boi_db_out=""
  boi_db_exit=0
  boi_db_out="$(bash "$BOI_DB_CHECK" 2>&1)" || boi_db_exit=$?
  if [ "$boi_db_exit" -eq 0 ]; then
    _pass "$boi_db_out"
  else
    _error "$boi_db_out"
  fi
fi

# ─── Message Roundtrip check ─────────────────────────────────────────────────
# Targets the `health-probe` agent (skip_llm) — exercises the wake plumbing
# (inbox → mark_delivered → audit) without an LLM call. Fast and free.
MSG_ROUNDTRIP_CHECK="$SCRIPTS_DIR/health/check-message-roundtrip.sh"
if [ -f "$MSG_ROUNDTRIP_CHECK" ]; then
  MODULE_COUNT=$((MODULE_COUNT + 1))
  echo ""
  echo -e "${BOLD}Message Roundtrip${RESET}"
  echo "  ─────────────────────────────────────────"
  bash "$MSG_ROUNDTRIP_CHECK" 2>&1 | tee "$DOCTOR_TMP.msgrt"
  msg_rt_exit="${PIPESTATUS[0]}"
  if [ "$msg_rt_exit" -eq 0 ]; then
    PASS_COUNT=$((PASS_COUNT + 1))
  else
    ERROR_COUNT=$((ERROR_COUNT + 1))
    HAS_ERRORS=true
  fi
  rm -f "$DOCTOR_TMP.msgrt"
fi

# ─── Message Divergence check ────────────────────────────────────────────────
MSG_DIVERGENCE_CHECK="$SCRIPTS_DIR/health/check-message-divergence.sh"
if [ -f "$MSG_DIVERGENCE_CHECK" ]; then
  MODULE_COUNT=$((MODULE_COUNT + 1))
  echo ""
  echo -e "${BOLD}Message Divergence${RESET}"
  echo "  ─────────────────────────────────────────"
  msg_div_out=""
  msg_div_exit=0
  msg_div_out="$(bash "$MSG_DIVERGENCE_CHECK" 2>&1)" || msg_div_exit=$?
  if [ "$msg_div_exit" -eq 0 ]; then
    _pass "$msg_div_out"
  else
    _error "$msg_div_out"
  fi
fi

# ─── Career Auto-Send Pipeline check ─────────────────────────────────────────
CAREER_PIPELINE_CHECK="$SCRIPTS_DIR/health/check-career-pipeline.sh"
if [ -f "$CAREER_PIPELINE_CHECK" ]; then
  MODULE_COUNT=$((MODULE_COUNT + 1))
  echo ""
  echo -e "${BOLD}Career Auto-Send Pipeline${RESET}"
  echo "  ─────────────────────────────────────────"
  career_out=""
  career_exit=0
  career_out="$(bash "$CAREER_PIPELINE_CHECK" --dry-run 2>&1)" || career_exit=$?
  if [ "$career_exit" -eq 0 ]; then
    _pass "$career_out"
  else
    _error "$career_out"
  fi
fi

# ─── Fleet Pulse check ───────────────────────────────────────────────────────
# Note: SCRIPTS_DIR may be overridden by sourced check files; use absolute path.
FLEET_PULSE_CHECK="$HEX_DIR/.hex/scripts/health/check-fleet-pulse.sh"
if [ -f "$FLEET_PULSE_CHECK" ]; then
  MODULE_COUNT=$((MODULE_COUNT + 1))
  echo ""
  echo -e "${BOLD}Fleet Pulse${RESET}"
  echo "  ─────────────────────────────────────────"
  fleet_pulse_out=""
  fleet_pulse_exit=0
  fleet_pulse_out="$(bash "$FLEET_PULSE_CHECK" --dry-run 2>&1)" || fleet_pulse_exit=$?
  if [ "$fleet_pulse_exit" -eq 0 ]; then
    _pass "$fleet_pulse_out"
  else
    _error "$fleet_pulse_out"
  fi
fi

# ─── Stalled Initiative Monitor check ────────────────────────────────────────
STALLED_INIT_CHECK="$HEX_DIR/.hex/scripts/health/check-stalled-initiatives.sh"
if [ -f "$STALLED_INIT_CHECK" ]; then
  MODULE_COUNT=$((MODULE_COUNT + 1))
  echo ""
  echo -e "${BOLD}Stalled Initiative Monitor${RESET}"
  echo "  ─────────────────────────────────────────"
  stalled_out=""
  stalled_exit=0
  stalled_out="$(bash "$STALLED_INIT_CHECK" --dry-run 2>&1)" || stalled_exit=$?
  if [ "$stalled_exit" -eq 0 ]; then
    _pass "$stalled_out"
  else
    _error "$stalled_out"
  fi
fi

# ─── Failure Routing Roundtrip check ─────────────────────────────────────────
FAILURE_ROUTING_CHECK="$HEX_DIR/.hex/scripts/health/check-failure-routing-roundtrip.sh"
if [ -f "$FAILURE_ROUTING_CHECK" ]; then
  MODULE_COUNT=$((MODULE_COUNT + 1))
  echo ""
  echo -e "${BOLD}Failure Routing Roundtrip${RESET}"
  echo "  ─────────────────────────────────────────"
  fr_out=""
  fr_exit=0
  fr_out="$(bash "$FAILURE_ROUTING_CHECK" 2>&1)" || fr_exit=$?
  if [ "$fr_exit" -eq 0 ]; then
    _pass "$fr_out"
  else
    _error "$fr_out"
  fi
fi

# ─── Slack Alert Roundtrip check ─────────────────────────────────────────────
SLACK_ROUNDTRIP_CHECK="$SCRIPTS_DIR/health/check-slack-alert-roundtrip.sh"
if [ -f "$SLACK_ROUNDTRIP_CHECK" ]; then
  MODULE_COUNT=$((MODULE_COUNT + 1))
  echo ""
  echo -e "${BOLD}Slack Alert Roundtrip${RESET}"
  echo "  ─────────────────────────────────────────"
  slack_rt_out=""
  slack_rt_exit=0
  slack_rt_out="$(bash "$SLACK_ROUNDTRIP_CHECK" 2>&1)" || slack_rt_exit=$?
  if [ "$slack_rt_exit" -eq 0 ]; then
    _pass "$slack_rt_out"
  else
    _error "$slack_rt_out"
  fi
fi

# ─── Summary ──────────────────────────────────────────────────────────────────
echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

if $CHAIN_STOPPED; then
  echo -e "  ${YELLOW}⚠ Memory module had errors — dependent modules were skipped${RESET}"
fi

echo -e "  ${BOLD}Summary:${RESET} ${MODULE_COUNT} modules checked"
echo -e "           ${PASS_COUNT} checks passed, ${WARN_COUNT} warnings, ${ERROR_COUNT} errors, ${FIXED_COUNT} auto-fixed"

if $HAS_ERRORS; then
  echo ""
  echo -e "  ${RED}✗ System not healthy — run with --fix to attempt auto-remediation${RESET}"
elif $HAS_WARNINGS; then
  echo ""
  echo -e "  ${YELLOW}⚠ Some warnings detected — run with --fix to resolve${RESET}"
else
  echo ""
  echo -e "  ${GREEN}✓ All systems healthy${RESET}"
fi
echo ""

# ─── Exit code ────────────────────────────────────────────────────────────────
if $HAS_ERRORS; then
  exit 1
elif $HAS_WARNINGS; then
  exit 2
fi
exit 0
